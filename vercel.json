{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "BASE_PATH=/ PORT=3000 pnpm --filter @workspace/connect build",
  "outputDirectory": "artifacts/connect/dist/public",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/" }
  ]
}
