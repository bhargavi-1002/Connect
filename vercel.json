{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "connect",
  "framework": "vite",
  "packageManager": "pnpm",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/connect build",
  "outputDirectory": "artifacts/connect/dist/public",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/"
  }
}
